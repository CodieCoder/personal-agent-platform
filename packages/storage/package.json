{
  "name": "@pap/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "pnpm --filter @pap/contracts build && pnpm --filter @pap/shared build && tsc --noEmit -p tsconfig.json",
    "lint": "biome lint .",
    "test": "pnpm run build && vitest run \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "@pap/contracts": "workspace:*",
    "@pap/shared": "workspace:*"
  }
}
